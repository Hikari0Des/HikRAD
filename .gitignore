# Secrets & local state — never commit
deploy/.env
*.env.local

# Runtime data (bind mounts from deploy/compose.yml)
deploy/data/
data/

# Go
backend/bin/
*.test
*.out
*.exe
coverage.*
# Toolchain tarballs downloaded for WSL2 dev (never commit)
go*.linux-amd64.tar.gz

# Node / frontend
node_modules/
frontend/*/dist/
frontend/*/.vite/
*.tsbuildinfo

# Editors & OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Backups & licenses (production artifacts live in /opt/hikrad, not the repo)
backups/
licenses/

# Evidence pack: raw per-run JSON is regenerated by docs/evidence/generate.sh
# every run; only the rendered dated reports under docs/evidence/reports/ are
# committed (Phase 5, contract C6).
docs/evidence/raw/

