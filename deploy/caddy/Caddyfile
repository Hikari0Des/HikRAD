# HikRAD reverse proxy — contract C5 (Phase 1, Agent A).
#   /        -> admin panel static dist   (frontend/panel,  Agent E)
#   /portal  -> subscriber portal dist    (frontend/portal, Agent F)
#   /api/*   -> hikrad-api:8080           (REST API, /api/v1/...)
#
# Note: only /api/* is proxied. The FreeRADIUS policy endpoint
# (POST /internal/radius/authorize, contract C4) is served on the same
# backend port but is deliberately NOT reachable through Caddy.

# Offline-first default (NFR-7, FR-49.5): a self-signed certificate covering
# this server's own detected IP address(es), generated by install.sh into
# data/caddy-selfsigned/{cert,key}.pem (regenerate by deleting that directory
# and re-running install.sh, or switch to Let's Encrypt with --domain below).
# Browsers will warn (untrusted CA) until you trust it or use --domain.
#
# --- Let's Encrypt instead (needs a public domain + internet) ---
# `sudo ./scripts/install.sh --domain hikrad.example.isp` does steps 1-2 below
# for you (and saves this file as Caddyfile.orig first). To do it by hand
# instead:
# 1. Replace the bare `:443` site address below with your domain, e.g.
#      hikrad.example.isp {
# 2. Delete the `tls /etc/caddy/selfsigned/...` line (Caddy then provisions
#    Let's Encrypt certificates automatically).
# 3. Optionally set a contact email in a global block at the top:
#      {
#          email admin@example.isp
#      }

:443 {
	# A named site address (e.g. `localhost:443`) only ever matches a TLS
	# handshake whose SNI names that exact host — but browsers send NO SNI at
	# all when connecting to a bare IP address (RFC 6066), which is exactly
	# how a technician reaches a freshly installed server before any
	# domain/DNS exists. A `localhost`-only cert 404s on cert selection then
	# ("no certificate available" -> ERR_SSL_PROTOCOL_ERROR), and `tls
	# internal`'s on-demand issuance can't help either since a bare `:443`
	# still has no requested name to mint one for. Found live in the Phase-5
	# M4 gate rehearsal (curl https://localhost worked; a browser hitting the
	# server's real LAN IP got a raw TLS alert). Fix: a static cert whose SAN
	# list explicitly covers every address install.sh detected on this host,
	# served for this catch-all block regardless of what SNI (or none) the
	# client sent.
	tls /etc/caddy/selfsigned/cert.pem /etc/caddy/selfsigned/key.pem
	encode gzip

	# ASVS V9.1/V14 baseline hardening. HSTS is safe even with the self-signed
	# dev default: it only ever tells a browser "use HTTPS for this host", it
	# has nothing to do with certificate trust, so it doesn't change the
	# self-signed warning behavior. No `preload`: that's a one-way submission
	# to browser vendors, inappropriate for a variable per-install hostname.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "same-origin"
	}

	handle /api/* {
		reverse_proxy hikrad-api:8080
	}

	redir /portal /portal/

	# Portal dist is mounted at /srv/portal; the /portal prefix is stripped
	# so the SPA is built and served from its own root (Vite base config is
	# Agent F's side of this contract).
	handle_path /portal/* {
		root * /srv/portal
		try_files {path} /index.html
		file_server
	}

	# Everything else: admin panel SPA.
	handle {
		root * /srv/panel
		try_files {path} /index.html
		file_server
	}
}

:80 {
	redir https://{host}{uri} permanent
}
