# HikRAD environment — contract C5 env names (Phase 1, Agent A).
#
# Do NOT fill this in by hand: run  scripts/gen-env.sh deploy/.env  to generate
# real secrets. This file documents the shape and safe defaults only.
# The generated .env is gitignored and must never be committed.

# --- Postgres (compose-internal; the app uses HIKRAD_DB_URL below) ---
POSTGRES_USER=hikrad
POSTGRES_PASSWORD=CHANGE_ME_generated_by_gen-env
POSTGRES_DB=hikrad

# --- Frozen app env names (C5) — all three Go binaries read these ---
# Postgres over the compose network (service name `postgres`).
HIKRAD_DB_URL=postgres://hikrad:CHANGE_ME_generated_by_gen-env@postgres:5432/hikrad?sslmode=disable
# Redis over the compose network (service name `redis`).
HIKRAD_REDIS_URL=redis://redis:6379/0
# 32 bytes, base64 — AES-256-GCM key for reversible subscriber RADIUS
# passwords (NFR-4.2). Losing this key makes CHAP auth impossible: back it up.
HIKRAD_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_-base64_32
# HMAC secret for panel/portal access + refresh tokens.
HIKRAD_JWT_SECRET=CHANGE_ME_generated_by_gen-env
# dev enables the Phase-1 auth stub (admin/admin) and seed data paths (C7).
# Production installs must use prod.
HIKRAD_ENV=dev

# --- Optional overrides ---
# Where container state lives on the host. Dev default: ./data next to
# compose.yml. Production installs set /opt/hikrad/data (scripts/install.sh).
#HIKRAD_DATA_DIR=./data
